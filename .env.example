# ── Database ──────────────────────────────────────────────
POSTGRES_DB=creet
POSTGRES_USER=creet
POSTGRES_PASSWORD=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=creetminio
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=creet-media
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://creet.ai/storage

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://creet.ai/api/auth/google/callback

# ── Encryption ────────────────────────────────────────────
FERNET_KEY=generate-with-python-cryptography-fernet-generate-key

# ── AI Providers (system-level defaults) ──────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=

# ── Email ─────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@creet.ai

# ── App ───────────────────────────────────────────────────
APP_NAME=VideoCraft
APP_URL=https://creet.ai
ENVIRONMENT=production
DEBUG=false
POLICY_VERSION=2026-03-04

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://creet.ai/api
NEXT_PUBLIC_WS_URL=wss://creet.ai/ws
